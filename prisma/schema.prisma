generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// USER & AUTH

model User {
  id              Int       @id @default(autoincrement())
  name            String?
  phone           String?
  password        String?
  isVerified      Boolean   @default(false) @map("is_verified")
  phoneVerifiedAt DateTime? @map("phone_verified_at")

  // ADMIN users can access panel and use RBAC roles.
  // BUYER/SELLER users are OTP-first and typically do not use password login.
  type   UserType   @default(BUYER)
  status UserStatus @default(PENDING_VERIFICATION)

  isActive       Boolean   @default(true) @map("is_active")
  blockedAt      DateTime? @map("blocked_at")
  lastLoginAt    DateTime? @map("last_login_at")
  lastOtpAt      DateTime? @map("last_otp_at")
  otpAttempts    Int       @default(0) @map("otp_attempts")
  otpLockedUntil DateTime? @map("otp_locked_until")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  roles UserRole[]

  dealsAsBuyer  Deal[] @relation("buyerDeals")
  dealsAsSeller Deal[] @relation("sellerDeals")

  sentMessages Message[] @relation("MessageSender")

  verifiedPayments Payment[] @relation("verifiedBy")
  resolvedDisputes Dispute[] @relation("resolvedBy")

  identities Identity[]

  @@index([phone])
  @@index([type, status])
  @@map("users")
}

model Identity {
  id         String  @id @default(uuid())
  deviceId   String  @unique // browser/device identifier
  ip         String?
  fingerprint Json?    // ব্রাউজারের হার্ডওয়্যার ডিটেইলস সেভ রাখার জন্য
  userAgent  String?
  trustLevel Int     @default(0) // 0=guest,1=verified,2=trusted

  // optional link to User (OTP verify করলে attach হবে)
  userId Int?
  user   User? @relation(fields: [userId], references: [id])

  buyerDeals  Deal[] @relation("DealBuyerIdentity")
  sellerDeals Deal[] @relation("DealSellerIdentity")

  createdAt DateTime @default(now())

  @@index([deviceId])
  @@map("identities")
}

model Role {
  id        Int      @id @default(autoincrement())
  name      String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  roles RolePermission[]

  @@map("permissions")
}

model UserRole {
  id Int @id @default(autoincrement())

  userId Int @map("user_id")
  roleId Int @map("role_id")

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model RolePermission {
  id Int @id @default(autoincrement())

  roleId       Int @map("role_id")
  permissionId Int @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

// OTP

model OTP {
  id        Int      @id @default(autoincrement())
  phone     String
  code      String
  expiresAt DateTime @map("expires_at")
  isUsed    Boolean  @default(false) @map("is_used")
  attempts  Int      @default(0)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([phone])
  @@index([phone, isUsed, expiresAt])
  @@map("otps")
}

// DEAL CORE

model Deal {
  id     Int        @id @default(autoincrement())
  item String? 
  amount Decimal    @db.Decimal(18, 2)
  status DealStatus @default(CREATED)

  paymentRef String @unique @map("payment_ref")

  // secure invite access (seller join করবে)
  inviteToken     String?   @unique
  inviteExpiresAt DateTime?

  // allow guest deals where one or both sides are not yet backed by a User row
  buyerId  Int? @map("buyer_id")
  sellerId Int? @map("seller_id")

  // keep guest-level identifying metadata for each side
  buyerPhone  String? @map("buyer_phone")
  sellerPhone String? @map("seller_phone")

  buyerDeviceId  String?
  sellerDeviceId String?
  buyerIdentityId  String? @map("buyer_identity_id")
  sellerIdentityId String? @map("seller_identity_id")

  buyer  User? @relation("buyerDeals", fields: [buyerId], references: [id])
  seller User? @relation("sellerDeals", fields: [sellerId], references: [id])
  buyerIdentity  Identity? @relation("DealBuyerIdentity", fields: [buyerIdentityId], references: [id])
  sellerIdentity Identity? @relation("DealSellerIdentity", fields: [sellerIdentityId], references: [id])

  messages     Message[]
  escrow       Escrow?
  payments     Payment[]
  disputes     Dispute[]
  audits       AuditLog[]
  transactions Transaction[]
  charge       DealCharge?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([buyerId])
  @@index([sellerId])
  @@index([buyerDeviceId, createdAt])
  @@index([sellerDeviceId, createdAt])
  @@index([buyerPhone])
  @@index([sellerPhone])
  @@index([status, createdAt])
  @@map("deals")
}

model Message {
  id       Int         @id @default(autoincrement())
  dealId   Int         @map("deal_id")
  senderId Int?        @map("sender_id")
  content  String
  type     MessageType

  // sender type clarity
  senderType MessageSenderType

  createdAt DateTime @default(now()) @map("created_at")

  deal   Deal  @relation(fields: [dealId], references: [id])
  sender User? @relation("MessageSender", fields: [senderId], references: [id])

  @@index([dealId])
  @@map("messages")
}

// ESCROW

model Escrow {
  id     Int @id @default(autoincrement())
  dealId Int @unique @map("deal_id")

  amount     Decimal      @db.Decimal(18, 2)
  status     EscrowStatus @default(HELD)
  // lifecycle tracking
  heldAt     DateTime     @default(now())
  releasedAt DateTime?    @map("released_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  deal Deal @relation(fields: [dealId], references: [id])

  @@map("escrows")
}

// PAYMENT SYSTEM

model Payment {
  id     Int @id @default(autoincrement())
  dealId Int @map("deal_id")

  trxId String @map("trx_id")

  paymentMethodId Int           @map("payment_method_id")
  method          PaymentMethod @relation(fields: [paymentMethodId], references: [id])

  status PaymentStatus @default(PENDING)

  idempotencyKey String @map("idempotency_key")

  // direction (in/out)
  direction PaymentDirection

  ipAddress  String? @map("ip_address")
  deviceInfo String? @map("device_info")

  // raw gateway response
  gatewayResponse Json?

  verifiedBy     Int?  @map("verified_by")
  verifiedByUser User? @relation("verifiedBy", fields: [verifiedBy], references: [id])

  verifiedAt DateTime? @map("verified_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  deal Deal @relation(fields: [dealId], references: [id])

  @@unique([dealId, idempotencyKey])
  @@unique([trxId, paymentMethodId])
  @@index([dealId, status])
  @@index([paymentMethodId, createdAt])
  @@map("payments")
}

model PaymentMethod {
  id   Int    @id @default(autoincrement())
  name String @unique // BKASH, NAGAD
  type String // MOBILE_BANKING, CARD, BANK

  isActive Boolean @default(true) @map("is_active")
  // dynamic config (number, api key etc)
  config   Json?

  createdAt DateTime @default(now()) @map("created_at")

  payments Payment[]
  charges  ServiceChargeConfig[]

  @@map("payment_methods")
}

// SERVICE CHARGE SYSTEM

model ServiceChargeConfig {
  id Int @id @default(autoincrement())

  paymentMethodId Int           @map("payment_method_id")
  method          PaymentMethod @relation(fields: [paymentMethodId], references: [id])

  type        ChargeType
  percentage  Decimal?   @db.Decimal(5, 2)
  fixedAmount Decimal?   @db.Decimal(18, 2)

  payer ChargePayer

  isActive Boolean @default(true) @map("is_active")

  // versioning
  version Int @default(1)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([paymentMethodId, version])
  @@map("service_charge_configs")
}

model DealCharge {
  id Int @id @default(autoincrement())

  dealId Int  @unique @map("deal_id")
  deal   Deal @relation(fields: [dealId], references: [id])

  baseAmount Decimal @map("base_amount") @db.Decimal(18, 2)

  chargeType  ChargeType @map("charge_type")
  chargeValue Decimal    @map("charge_value") @db.Decimal(18, 2)

  totalCharge Decimal @map("total_charge") @db.Decimal(18, 2)

  payer ChargePayer

  buyerPays  Decimal @map("buyer_pays") @db.Decimal(18, 2)
  sellerPays Decimal @map("seller_pays") @db.Decimal(18, 2)

  buyerTotal     Decimal @map("buyer_total") @db.Decimal(18, 2)
  sellerReceives Decimal @map("seller_receives") @db.Decimal(18, 2)

  createdAt DateTime @default(now()) @map("created_at")

  @@map("deal_charges")
}

// DISPUTE

model Dispute {
  id     Int @id @default(autoincrement())
  dealId Int @map("deal_id")

  reason String
  status DisputeStatus @default(OPEN)

  resolvedBy     Int?  @map("resolved_by")
  resolvedByUser User? @relation("resolvedBy", fields: [resolvedBy], references: [id])

  resolvedAt DateTime? @map("resolved_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  deal Deal @relation(fields: [dealId], references: [id])

  @@index([dealId])
  @@map("disputes")
}

// AUDIT LOG

model AuditLog {
  id Int @id @default(autoincrement())

  dealId Int? @map("deal_id")
  userId Int? @map("user_id")

  action     String
  entityType String @map("entity_type")
  entityId   Int?   @map("entity_id")

  ipAddress String? @map("ip_address")
  meta      Json?

  // 🔥 NEW: device tracking
  deviceId String?

  createdAt DateTime @default(now()) @map("created_at")

  deal Deal? @relation(fields: [dealId], references: [id])

  @@index([dealId, createdAt])
  @@index([userId, createdAt])
  @@map("audit_logs")
}

// TRANSACTION LEDGER

model Transaction {
  id     Int @id @default(autoincrement())
  dealId Int @map("deal_id")

  type   TransactionType
  amount Decimal         @db.Decimal(18, 2)

  // 🔥 NEW: better reference tracking
  referenceId   Int?
  referenceType String?

  createdAt DateTime @default(now()) @map("created_at")

  deal Deal @relation(fields: [dealId], references: [id])

  @@index([dealId])
  @@map("transactions")
}

model RequestLog {
  id Int @id @default(autoincrement())

  ip       String
  deviceId String?
  path     String

  createdAt DateTime @default(now())

  @@index([ip, createdAt])
  @@map("request_logs")
}

// ENUMS

enum DealStatus {
  CREATED
  AWAITING_PAYMENT
  PAID
  DELIVERED
  COMPLETED
  DISPUTED
  CANCELLED
  EXPIRED // 🔥 NEW
}

enum EscrowStatus {
  HELD
  RELEASED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  VERIFIED
  FAILED
}

enum PaymentDirection {
  IN
  OUT
}

enum MessageType {
  USER
  SYSTEM
}

enum MessageSenderType {
  USER
  SYSTEM
  ADMIN
}

enum DisputeStatus {
  OPEN
  RESOLVED
  REJECTED
}

enum TransactionType {
  PAYMENT_RECEIVED
  ESCROW_HELD
  ESCROW_RELEASED
  REFUND
}

enum ChargeType {
  PERCENTAGE
  FIXED
}

enum ChargePayer {
  BUYER
  SELLER
  SPLIT
}

enum UserType {
  ADMIN
  BUYER
  SELLER
}

enum UserStatus {
  PENDING_VERIFICATION
  VERIFIED
  SUSPENDED
  CLOSED
}
