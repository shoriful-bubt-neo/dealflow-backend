// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         Int     @id @default(autoincrement())
  phone      String  @unique
  password   String?
  isVerified Boolean @default(false) @map("is_verified")

  isActive    Boolean   @default(true) @map("is_active")
  lastLoginAt DateTime? @map("last_login_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  roles UserRole[]

  dealsAsBuyer  Deal[] @relation("buyerDeals")
  dealsAsSeller Deal[] @relation("sellerDeals")

  @@index([phone])
  @@map("users")
}

model Role {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  roles RolePermission[]

  @@map("permissions")
}

model UserRole {
  id Int @id @default(autoincrement())

  userId Int @map("user_id")
  roleId Int @map("role_id")

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model RolePermission {
  id Int @id @default(autoincrement())

  roleId       Int @map("role_id")
  permissionId Int @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model OTP {
  id        Int      @id @default(autoincrement())
  phone     String
  code      String
  expiresAt DateTime @map("expires_at")
  isUsed    Boolean  @default(false) @map("is_used")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([phone])
  @@map("otps")
}

model Deal {
  id     Int        @id @default(autoincrement())
  amount Float
  status DealStatus @default(CREATED)

  paymentRef String @unique @map("payment_ref")

  buyerId  Int @map("buyer_id")
  sellerId Int @map("seller_id")

  buyer  User @relation("buyerDeals", fields: [buyerId], references: [id])
  seller User @relation("sellerDeals", fields: [sellerId], references: [id])

  messages     Message[]
  escrow       Escrow?
  payments     Payment[]
  disputes     Dispute[]
  audits       AuditLog[]
  transactions Transaction[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
  @@map("deals")
}

model Message {
  id       Int         @id @default(autoincrement())
  dealId   Int         @map("deal_id")
  senderId Int?        @map("sender_id")
  content  String
  type     MessageType

  createdAt DateTime @default(now()) @map("created_at")

  deal Deal @relation(fields: [dealId], references: [id])

  @@index([dealId])
  @@map("messages")
}

model Escrow {
  id     Int @id @default(autoincrement())
  dealId Int @unique @map("deal_id")

  amount Float
  status EscrowStatus @default(HELD)

  releasedAt DateTime? @map("released_at")

  deal Deal @relation(fields: [dealId], references: [id])

  @@map("escrows")
}

model Payment {
  id     Int @id @default(autoincrement())
  dealId Int @map("deal_id")

  trxId           String @map("trx_id")
  paymentMethodId Int    @map("payment_method_id")

  method PaymentMethod @relation(fields: [paymentMethodId], references: [id])
  status PaymentStatus @default(PENDING)

  idempotencyKey String? @unique @map("idempotency_key")

  ipAddress  String? @map("ip_address")
  deviceInfo String? @map("device_info")

  verifiedBy Int?      @map("verified_by") // admin id
  verifiedAt DateTime? @map("verified_at")

  createdAt DateTime @default(now()) @map("created_at")

  deal Deal @relation(fields: [dealId], references: [id])

  @@index([dealId])
  @@index([trxId])
  @@map("payments")
}

model PaymentMethod {
  id   Int    @id @default(autoincrement())
  name String @unique // BKASH, NAGAD
  type String // MOBILE_BANKING, CARD, BANK

  isActive Boolean @default(true) @map("is_active")

  // dynamic config (number, api key etc)
  config Json?

  createdAt DateTime @default(now()) @map("created_at")

  payments Payment[]

  @@map("payment_methods")
}

model Dispute {
  id     Int @id @default(autoincrement())
  dealId Int @map("deal_id")

  reason String
  status DisputeStatus @default(OPEN)

  resolvedBy Int?      @map("resolved_by")
  resolvedAt DateTime? @map("resolved_at")

  createdAt DateTime @default(now()) @map("created_at")

  deal Deal @relation(fields: [dealId], references: [id])

  @@index([dealId])
  @@map("disputes")
}

model AuditLog {
  id Int @id @default(autoincrement())

  dealId Int? @map("deal_id")
  userId Int? @map("user_id")

  action String
  meta   Json?

  ipAddress String? @map("ip_address")

  createdAt DateTime @default(now()) @map("created_at")

  deal Deal? @relation(fields: [dealId], references: [id])

  @@index([dealId])
  @@index([userId])
  @@map("audit_logs")
}

model Transaction {
  id     Int @id @default(autoincrement())
  dealId Int @map("deal_id")

  type   TransactionType
  amount Float

  reference String?
  createdAt DateTime @default(now()) @map("created_at")

  deal Deal @relation(fields: [dealId], references: [id])

  @@index([dealId])
  @@map("transactions")
}

enum DealStatus {
  CREATED
  AWAITING_PAYMENT
  PAID
  DELIVERED
  COMPLETED
  DISPUTED
  CANCELLED
}

enum EscrowStatus {
  HELD
  RELEASED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  VERIFIED
  FAILED
}

enum MessageType {
  USER
  SYSTEM
}

enum DisputeStatus {
  OPEN
  RESOLVED
  REJECTED
}

enum TransactionType {
  PAYMENT_RECEIVED
  ESCROW_HELD
  ESCROW_RELEASED
  REFUND
}
